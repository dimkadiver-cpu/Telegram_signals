# ── Exchange ─────────────────────────────────────────────────────────────────
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET=false

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_REVIEW_CHAT_ID=your_review_chat_id     # chat dove ricevi le bozze
TELEGRAM_CHANNEL_ID=your_channel_id             # canale pubblico di destinazione

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./telegram_signals.db
# Per produzione:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/telegram_signals

# ── Risk ──────────────────────────────────────────────────────────────────────
RISK_CAPITAL_USD=10000.0
RISK_PCT=1.0
